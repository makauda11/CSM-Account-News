async function fetchGmail(client){
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,
        system:'You are a CSM assistant. Search Gmail for the most recent email related to the given client. Return ONLY a JSON object with keys: subject, from, date, summary. No markdown, no extra text.',
        messages:[{role:'user',content:'Search Gmail for the most recent email related to client: '+client.name+'. Return JSON.'}],
        mcp_servers:[{type:'url',url:'https://gmail.mcp.claude.com/mcp',name:'gmail-mcp'}]})});
    const d=await r.json();
    const t=d.content?.filter(b=>b.type==='text').map(b=>b.text).join('');
    liveEmails[client.id]=JSON.parse(t.replace(/```json|```/g,'').trim());
  }catch(e){}
}

async function fetchLinear(client){
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,
        system:'You are a CSM assistant. Search Linear for the most recent issue for the given client. Return ONLY a JSON object with keys: title, status, desc, url. No markdown.',
        messages:[{role:'user',content:'Search Linear for most recent issue for client: '+client.name+'. Return JSON.'}],
        mcp_servers:[{type:'url',url:'https://mcp.linear.app/mcp',name:'linear-mcp'}]})});
    const d=await r.json();
    const t=d.content?.filter(b=>b.type==='text').map(b=>b.text).join('');
    liveTickets[client.id]=JSON.parse(t.replace(/```json|```/g,'').trim());
  }catch(e){}
}

async function refreshAll(){
  const btn=document.getElementById('refresh-btn');
  const lbl=document.getElementById('refresh-label');
  btn.classList.add('loading');lbl.textContent='Actualizando...';
  await Promise.all(clients.map(c=>Promise.all([fetchGmail(c),fetchLinear(c)])));
  renderCards();
  btn.classList.remove('loading');lbl.textContent='Actualizar';
}

