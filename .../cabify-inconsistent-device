function getWeek(){
  const n=new Date(2026,2,20),d=n.getDay(),diff=n.getDate()-d+(d===0?-6:1),m=new Date(n);
  m.setDate(diff);
  return 'Semana del '+m.getDate()+' '+m.toLocaleString('es-ES',{month:'short'})+' '+m.getFullYear();
}

function darken(hex,amt=0.25){
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return 'rgb('+Math.max(0,Math.floor(r*(1-amt)))+','+Math.max(0,Math.floor(g*(1-amt)))+','+Math.max(0,Math.floor(b*(1-amt)))+')';
}

function initials(name){return name.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase();}

let currentFilter='all';
let liveEmails={};
let liveTickets={};

function renderFilters(){
  const counts={all:clients.length,red:clients.filter(c=>c.health==='red').length,yellow:clients.filter(c=>c.health==='yellow').length,green:clients.filter(c=>c.health==='green').length};
  const f=document.getElementById('filters');
  f.innerHTML=[['all','Todos','active-all'],['red','En riesgo','active-red'],['yellow','Atención','active-yellow'],['green','Saludables','active-green']].map(([v,l,cls])=>
    `<button class="filter-btn ${currentFilter===v?cls:''}" onclick="setFilter('${v}')">${l} <span class="badge" style="background:${currentFilter===v?'currentColor':'#e5e7eb'};color:${currentFilter===v?'#fff':'#6b7280'}">${counts[v]}</span></button>`
  ).join('');
}

function setFilter(f){currentFilter=f;renderFilters();renderCards();}

function renderCards(){
  const list=currentFilter==='all'?clients:clients.filter(c=>c.health===currentFilter);
  document.getElementById('cards').innerHTML=list.map(c=>renderCard(c)).join('');
}

