    .refresh-btn.loading .spin{animation:spin 1s linear infinite}

    /* Filters */
    .filters{background:#fff;border-bottom:0.5px solid #e5e7eb;padding:10px 16px;display:flex;gap:8px;overflow-x:auto;-webkit-overflow-scrolling:touch}
    .filters::-webkit-scrollbar{display:none}
    .filter-btn{background:transparent;color:#6b7280;border:1px solid #e5e7eb;border-radius:20px;padding:5px 14px;font-size:12px;font-weight:700;white-space:nowrap;cursor:pointer;display:flex;align-items:center;gap:5px;-webkit-tap-highlight-color:transparent}
    .filter-btn.active-all{background:#f1f4fb;color:#374151;border-color:#374151}
    .filter-btn.active-red{background:#fee2e2;color:#dc2626;border-color:#dc2626}
    .filter-btn.active-yellow{background:#fef3c7;color:#b45309;border-color:#b45309}
    .filter-btn.active-green{background:#dcfce7;color:#16a34a;border-color:#16a34a}
    .badge{border-radius:10px;padding:0 7px;font-size:10px;font-weight:800}

    /* Cards */
    .cards{padding:16px}
    .card{background:#fff;border-radius:16px;border:0.5px solid #e5e7eb;margin-bottom:16px;overflow:hidden;box-shadow:0 1px 4px rgba(10,15,46,0.06)}
    .card-header{padding:14px 16px;display:flex;align-items:center;gap:12px}
    .logo-wrap{width:42px;height:42px;border-radius:10px;background:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;border:1px solid rgba(255,255,255,0.2)}
    .logo-wrap img{width:36px;height:36px;object-fit:contain}
    .logo-initials{width:42px;height:42px;border-radius:10px;background:rgba(255,255,255,0.18);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0}
    .client-name{font-weight:800;font-size:15px;color:#fff;line-height:1.2}
    .client-meta{font-size:11px;color:rgba(255,255,255,0.7);margin-top:2px}
    .health-badge{font-size:10px;font-weight:700;border-radius:20px;padding:3px 10px;white-space:nowrap;flex-shrink:0;margin-left:auto}
    .health-green{background:#dcfce7;color:#166534}
    .health-yellow{background:#fef3c7;color:#92400e}
    .health-red{background:#fee2e2;color:#991b1b}

    .card-body{padding:14px 16px}
    .section{margin-bottom:14px;padding-bottom:14px;border-bottom:0.5px solid #f3f4f6}
    .section:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
    .section-label{font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:5px;display:flex;align-items:center;gap:4px}
    .section-text{font-size:12.5px;color:#374151;line-height:1.6}
    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .news-box{background:#f8f9ff;border-radius:10px;padding:10px 12px}
    .risk-box{background:#fff8f0;border-radius:10px;padding:10px 12px;border-left:3px solid #d97706}
    .ticket-status{font-size:10px;background:#e0e7ff;color:#3730a3;border-radius:6px;padding:2px 8px;font-weight:700;display:inline-block;margin:4px 0}
    .link-btn{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:700;text-decoration:none;border-radius:6px;padding:3px 9px;margin-top:5px;border:1px solid}
    .action-box{background:#fff7ed;border-radius:10px;padding:12px 14px;border-left:4px solid #ea580c}
    .action-label{font-size:9.5px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:1px;margin-bottom:5px}
