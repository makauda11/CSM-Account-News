    @keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

    /* Banner */
    .banner{position:relative;width:100%;overflow:hidden;min-height:140px;background:linear-gradient(135deg,#0a0f2e 0%,#1e2ede 100%)}
    .banner img{width:100%;object-fit:cover;object-position:center top;display:block;max-height:200px}
    .banner-overlay{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(10,15,46,0.85) 0%,transparent 100%);padding:16px 20px 12px;display:flex;justify-content:space-between;align-items:flex-end}
